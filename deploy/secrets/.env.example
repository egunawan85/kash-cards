# deploy/secrets/.env.example  —  NON-SECRET config. Copy to ".env" and fill.
# Loaded into process env by deploy/scripts/load-env.ps1 (local) or injected per
# app-pool from config on the server. SECRETS go in .vault, not here.

# Environment gate: dev | prod  (gates code behavior; does NOT select the database)
QRYPTO_ENVIRONMENT=dev

# Database (the password is in .vault as DB_PASSWORD; the app assembles the
# connection string from these at deploy time)
DB_SERVER=your-sql-server.database.windows.net
DB_NAME=qrypto-card
DB_USER=app_login

# Provider endpoints (non-secret URLs)
WASABICARD_API_URL=https://sandbox-api-merchant.wasabicard.com
PGCRYPTO_API_URL=https://api.runegate.co

# Public cardholder app base URL — the host for links emailed/shared OUTSIDE the app:
# password-reset (/newpassword) and referral (/register). This is the QryptoCard.Dashboard
# (cardholder) host. REQUIRED, no code default: the INT reset link and the Dashboard referral
# link both Require PUBLIC_BASE_URL — the deploy ABORTS (inject-secrets KV preflight) if it is
# unset, and the readers fail closed (throw) on first use rather than emit a wrong host. So it
# MUST be set per environment before deploy (kash-int + kash-dashboard pools).
#   dev  = cardholder dev host (app-<env>.kash.cards, or the current CLOUDFLARE_QUICK_TUNNEL URL)
#   prod = https://app.kash.cards
PUBLIC_BASE_URL=https://app-dev.kash.cards

# Email (Postmark SMTP) — POSTMARK_SERVER_TOKEN is in .vault (used as BOTH the SMTP username and
# password). EMAIL_FROM must be a Postmark-verified sender signature on kash.cards.
EMAIL_FROM=no-reply@kash.cards
EMAIL_SMTP_GATEWAY=smtp.postmarkapp.com
EMAIL_SMTP_PORT=587
