# deploy/secrets/.env.example  —  NON-SECRET config template (one per project, all
# envs). Copy to a PER-ENV file ".env.<env>" (e.g. ".env.dev", ".env.prd") and fill
# that environment's values. Loaded into process env by deploy/scripts/load-env.ps1
# (local: `-Env <env>`) or injected per app-pool from Key Vault on the server (the
# per-env set chosen by ENV). SECRETS go in .vault.<env>, not here.

# Environment gate: dev | prod  (gates code behavior; does NOT select the database)
QRYPTO_ENVIRONMENT=dev

# Database (the password is in .vault as DB_PASSWORD; the app assembles the
# connection string from these at deploy time)
DB_SERVER=your-sql-server.database.windows.net
DB_NAME=qrypto-card
DB_USER=app_login

# Provider endpoints (non-secret URLs)
WASABICARD_API_URL=https://sandbox-api-merchant.wasabicard.com
PGCRYPTO_API_URL=https://api.runegate.co

# Public cardholder app base URL — the host for links emailed/shared OUTSIDE the app:
# password-reset (/newpassword) and referral (/register). This is the QryptoCard.Dashboard
# (cardholder) host. REQUIRED, no code default: the INT reset link and the Dashboard referral
# link both Require PUBLIC_BASE_URL — the deploy ABORTS (inject-secrets KV preflight) if it is
# unset, and the readers fail closed (throw) on first use rather than emit a wrong host. So it
# MUST be set per environment before deploy (kash-int + kash-dashboard pools).
#   dev  = cardholder dev host (app-<env>.kash.cards, or the current CLOUDFLARE_QUICK_TUNNEL URL)
#   prod = https://app.kash.cards
PUBLIC_BASE_URL=https://app-dev.kash.cards

# Admin-dashboard base URL — the host for the admin-invitation link (/InvitedAccount) emailed to
# invited staff. This is the QryptoCard.Dashboard.Admin host, DISTINCT from the cardholder
# PUBLIC_BASE_URL above. REQUIRED, no code default (the invite carries an auth token): the deploy
# ABORTS (inject-secrets KV preflight) if unset, and the INT reader fails closed rather than emit
# a wrong host. Set per environment before deploy (kash-int pool).
#   dev  = admin dev host (admin-<env>.kash.cards)
#   prod = https://admin.kash.cards
ADMIN_BASE_URL=https://admin-dev.kash.cards

# Email (Postmark SMTP) — POSTMARK_SERVER_TOKEN is in .vault (used as BOTH the SMTP username and
# password). EMAIL_FROM must be a Postmark-verified sender signature on kash.cards.
EMAIL_FROM=no-reply@kash.cards
EMAIL_SMTP_GATEWAY=smtp.postmarkapp.com
EMAIL_SMTP_PORT=587

# --- WasabiCard auto-funding (OPTIONAL; injected only if set; app defaults are safe/OFF) ---
# This is how the money-OUT auto-funding is turned on/configured PER ENVIRONMENT from the deploy.
# Leave ALL of these unset in dev -> auto-funding stays OFF and the rest use code defaults.
# In prd, set ENABLED=1 (and optionally override the address/thresholds) to turn it on.
#   ENABLED:   "1"/"true" = on, anything else / unset = OFF (default OFF — fail-safe)
#   *_USD / *_PCT / *_MIN: numeric overrides; unset -> code defaults (floor 500, target 700,
#       eager 500, daily cap 30000, min transfer 50, WasabiCard fee 1.4%, in-flight stale 60,
#       re-alert 6h). DEPOSIT_ADDRESS: the WasabiCard USDT-TRC20 destination (TRON, starts 'T').
#   OPS_ALERT_EMAIL: inbox for low-balance / cap / ambiguous-transfer alerts (else EMAIL_FROM).
# WASABICARD_AUTOFUND_ENABLED=1
# WASABICARD_FLOOR_USD=500
# WASABICARD_TARGET_USD=700
# WASABICARD_EAGER_THRESHOLD_USD=500
# WASABICARD_DAILY_CAP_USD=30000
# WASABICARD_MIN_TRANSFER_USD=50
# WASABICARD_WC_FEE_PCT=1.4
# WASABICARD_INFLIGHT_STALE_MIN=60
# WASABICARD_REALERT_HOURS=6
# WASABICARD_DEPOSIT_ADDRESS=TC75gyAywXztsQAmwLhkAvcYm6yEjjBEQP
# OPS_ALERT_EMAIL=ops@kash.cards

# --- Card pricing (OPTIONAL; injected only if set; unset => 0% markup = sell at wholesale) ---
# Customer CardPrice = ceil( WasabiCard wholesale OriginalCardPrice * (1 + CARD_PRICE_MARKUP%) ).
# WasabiCard's deposit fee is <=0.2% (covered by our 3% deposit fee), so ONLY the issuance price
# is marked up here. Leave unset -> cards sell at wholesale (break-even, never below cost).
#   CARD_PRICE_MARKUP:            global markup %, e.g. 30 (= +30%, rounded up to the next dollar).
#   CARD_PRICE_MARKUP_<cardTypeId>: per-card markup % override (add the specific name to inject-secrets
#                                  $OptionalConfigNames to seed it from KV), e.g. CARD_PRICE_MARKUP_111068.
#   CARD_PRICE_GLOBAL:           flat price for ALL cards, bypassing wholesale+markup (rarely needed).
# CARD_PRICE_MARKUP=30
# CARD_PRICE_GLOBAL=

# Bootstrap admin (the admin-dashboard login created by the DB seed). The email is
# non-secret and lives here; the password is in .vault as SEED_ADMIN_PASSWORD. In dev
# both may be left blank (vm-seed falls back to fixed dev defaults). In a NON-DEV
# environment BOTH are REQUIRED — vm-seed refuses to seed the dev-default admin off dev.
# NOTE: the admin seed is INSERT-ONLY, so the FIRST seeded password is permanent until
# rotated via the app — set it correctly the first time.
SEED_ADMIN_EMAIL=
