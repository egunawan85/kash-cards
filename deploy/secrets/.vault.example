# deploy/secrets/.vault.example  —  SECRETS template (one per project, all envs).
# Copy to a PER-ENV file ".vault.<env>" (e.g. ".vault.dev", ".vault.prd") and fill
# with that environment's ROTATED values. NEVER commit a ".vault.<env>" file. On the
# server these come from Key Vault (seed-kv-secrets.sh uploads the per-env set chosen
# by ENV). Every name here should also appear in a SecretsConfig.Preload(...) call so
# a missing value faults the app at startup -- EXCEPT deploy-time-only keys (e.g.
# SEED_ADMIN_PASSWORD, read by vm-seed at seed time, never by the running app).

# --- At-rest data key (AES-256-GCM master key for TOTP/2FA seeds, via AesUtility). ---
#     32-byte hex (64 chars). Generate with: openssl rand -hex 32
#     Passwords + API secrets are one-way bcrypt hashes and need NO key. The legacy
#     reversible DBKEY/APPKEY are retired (the old Rijndael cipher has been removed).
KASH_DATA_KEY=

# --- Database ---
DB_PASSWORD=

# --- WasabiCard (card issuer) ---
# All four are Require()'d across the INT / INT.Callback tiers, so all must be set.
WASABICARD_API_KEY=
WASABICARD_PUBLIC_KEY=
WASABICARD_PRIVATE_KEY=
WASABICARD_PRIVATE_KEY_XML=
# WasabiCard's OWN public key, for verifying their callbacks.
# Get the CURRENT value from WasabiCard — the committed one is stale.
WASABICARD_WSBPUBLIC_KEY=

# --- Runegate / PGCrypto (crypto gateway) ---
PGCRYPTO_API_KEY=
PGCRYPTO_SECRET_KEY=
# Per-merchant HMAC key Runegate signs outbound webhooks with (callback verification).
PGCRYPTO_WEBHOOK_SECRET=

# --- Email (Postmark) ---
# POSTMARK_SERVER_TOKEN is the Postmark server token (used as BOTH SMTP user and
# password). A legacy notification path Require()'s EMAIL_PASSWORD directly — set
# it to the SAME token value.
POSTMARK_SERVER_TOKEN=
EMAIL_PASSWORD=

# --- Internal: shared secret the API tier presents to the INT money tier (defense in
#     depth on the WCF callback service). Generate a random 32+ byte value. ---
INT_CALLBACK_SHARED_SECRET=

# --- Auth token revocation secret (dashboard/API -> AuthV1Service). Random 32+ bytes. ---
AUTH_SERVICE_REVOKE_TOKEN=

# --- Shared secret gating the reconciliation-sweep trigger endpoint
#     (POST /v1/payment/reconcile/pending, X-Scheduler-Auth header). The API.Callback host
#     is publicly reachable, so this secret is the sole gate — generate a STRONG random
#     32+ byte value. The on-box scheduled task reads it live from Key Vault each tick.
#     HARD STARTUP DEPENDENCY: API.Callback Preload()'s this in Global.asax at
#     Application_Start, so if it is unset the app fails to initialize and 503s from boot
#     (not a lazy/first-request failure; under IIS rapid-fail protection the pool can then
#     be stopped). Seed it in Key Vault before deploy — a per-tier `deploy.sh update
#     api-callback` against a vault missing this will bring the tier up broken. ---
SCHEDULER_SHARED_SECRET=

# --- Optional: git PAT for cloning a PRIVATE source repo on the build box. Leave blank
#     for a public repo. Seeded to Key Vault as REPO-TOKEN; vm-fetch-source pulls it via
#     the VM managed identity (never passed on argv / run-command params). ---
REPO_TOKEN=

# --- Bootstrap admin password (the admin-dashboard login created by the DB seed). The
#     matching email is SEED_ADMIN_EMAIL in .env (non-secret). vm-seed reads this from
#     Key Vault (SEED-ADMIN-PASSWORD) at seed time. DEV may leave it blank (vm-seed uses a
#     fixed dev default); a NON-DEV environment MUST set it (vm-seed fails closed otherwise).
#     INSERT-ONLY seed: the first value is permanent until rotated via the app — choose a
#     strong password the first time. ---
SEED_ADMIN_PASSWORD=
