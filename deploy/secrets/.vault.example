# deploy/secrets/.vault.example  —  SECRETS. Copy to ".vault" and fill with the
# ROTATED values. NEVER commit ".vault". On the server these come from Key Vault.
# Every name here should also appear in a SecretsConfig.Preload(...) call so a
# missing value faults the app at startup.

# --- App encryption keys (legacy; retired by the Plan 3 crypto migration) ---
DBKEY=
APPKEY=

# --- Database ---
DB_PASSWORD=

# --- WasabiCard (card issuer) ---
WASABICARD_API_KEY=
WASABICARD_PRIVATE_KEY_XML=
# WasabiCard's OWN public key, for verifying their callbacks (Plan 3).
# Get the CURRENT value from WasabiCard — the committed one is stale.
WASABICARD_WSBPUBLIC_KEY=

# --- Runegate / PGCrypto (crypto gateway) ---
PGCRYPTO_API_KEY=
PGCRYPTO_SECRET_KEY=
# Per-merchant HMAC key Runegate signs outbound webhooks with (Plan 3 callback verify).
PGCRYPTO_WEBHOOK_SECRET=

# --- Email (Postmark) ---
POSTMARK_SERVER_TOKEN=

# --- Internal: shared secret the API tier presents to the INT money tier (defense in
#     depth on the WCF callback service). Generate a random 32+ byte value. ---
INT_CALLBACK_SHARED_SECRET=
