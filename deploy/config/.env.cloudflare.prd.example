# deploy/config/.env.cloudflare.prd.example
# Cloudflare named-tunnel credentials for PROD. Copy to ".env.cloudflare.prd" and
# fill. The filled file is GITIGNORED; only this .example is committed.
#
# Prod always runs in NAMED-tunnel mode (CLOUDFLARE_QUICK_TUNNEL=false in
# .env.provision.prd), so these credentials are REQUIRED. They may also be supplied
# as environment variables instead of this file.
#
# TOKEN: use a NEW prod-only token (isolated from the dev token). Create it at
# Cloudflare -> My Profile -> API Tokens -> Create Custom Token:
#   - Zone : DNS : Edit
#   - Account : Cloudflare Tunnel : Edit
# Scope it to the s16.xyz zone for the temporary launch. At the kash.cards domain
# CUTOVER, add the kash.cards zone to this token's scope (or mint a kash.cards token).
#
# Only CLOUDFLARE_API_TOKEN is strictly required — ACCOUNT_ID and ZONE_ID can be
# derived from the token via the Cloudflare API (GET /accounts, GET /zones).

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ---------------------------------------------------------------------------
# ROUTES: the public URLs for prod (runegate-infra pattern).
# Each entry: "<prefix>:<service-url>"
#   hostname    = "<prefix>.<CLOUDFLARE_ZONE>"  (e.g. app.s16.xyz, later app.kash.cards)
#   service-url = the on-box loopback the tunnel forwards to (use 127.0.0.1, NOT
#                 localhost -- IIS binds IPv4 only). Port per deploy/config/sites.json.
# The zone is NOT in these entries (it comes from CLOUDFLARE_ZONE in .env.provision.prd),
# so the s16.xyz -> kash.cards cutover does NOT change this file -- only the prefixes
# differ from dev (no "-dev" suffix).
# Sites NOT listed here get NO public hostname (deploy-iis still builds them loopback-
# only). Backends (QryptoCard.API 8081, API.Admin 8083) are intentionally omitted -- the
# dashboards call them server-side over loopback. Scheduler (8085) + INT tiers + Scrapper
# stay internal too.
# ---------------------------------------------------------------------------
ROUTES=(
  "app:http://127.0.0.1:8087"        # QryptoCard.Dashboard        (customer/merchant UI)
  "admin:http://127.0.0.1:8088"      # QryptoCard.Dashboard.Admin  (admin UI, login-gated)
  "api:http://127.0.0.1:8082"        # QryptoCard.API.Public       (programmatic, API-key)
  "callback:http://127.0.0.1:8084"   # QryptoCard.API.Callback     (provider webhooks)
  "docs:http://127.0.0.1:8086"       # QryptoCard.APIDocs
)
