# deploy/config/.env.provision.prd.example
# Infra parameters for the PRODUCTION box. Copy to ".env.provision.prd" and fill
# the operator-specific blanks (subscription id, your admin source IP, Cloudflare).
# Sourced by the provision/deploy/perimeter scripts. Convention adapted from
# runegate-infra/config/.env.provision.<env>.
#
# The deploy ENV token for production is "prd" (matches the -prd resource names and
# vm-seed's accepted set dev/stg/prd). The app-level gate QRYPTO_ENVIRONMENT (in
# secrets/.env.prd) is a SEPARATE value and stays "prod".
#
# The filled ".env.provision.prd" is GITIGNORED (contains subscription id + IPs);
# only this .example is committed.
#
# Differences from dev (.env.provision.dev): SPLIT resource groups (permanent
# shared RG vs disposable compute RG), Key Vault purge protection ON, a NAMED
# Cloudflare tunnel (not the throwaway quick-tunnel), and the prod hostnames drop
# the "-dev" suffix. The app secret source is the prd set (secrets/.env.prd,
# secrets/.vault.prd) — see "App secrets source" below.

# ── Environment ──────────────────────────────────────────────────────────────
ENV=prd

# ── Azure subscription / region ──────────────────────────────────────────────
# Prod lives in the same subscription as the dev shakeout ("Subscription qrypto").
AZURE_SUBSCRIPTION_NAME="Subscription qrypto"
AZURE_SUBSCRIPTION_ID=          # <-- fill: az account show --subscription "Subscription qrypto" --query id -o tsv
AZURE_LOCATION=southeastasia    # Singapore

# ── Resource groups ──────────────────────────────────────────────────────────
# Prod SPLITS into two RGs: a PERMANENT shared RG that holds the stateful, hard-to-
# recreate resources (Key Vault + Log Analytics) and survives a compute rebuild, and
# a compute RG (VM + network) that can be torn down/rebuilt without losing secrets or
# logs. (Dev collapses both into one disposable RG.)
COMPUTE_RG=rg-kash-prd
SHARED_RG=rg-kash-shared

# ── Network (NSG denies inbound 443; the Cloudflare tunnel is outbound-only) ──
VNET_NAME=vnet-kash-prd
SUBNET_NAME=snet-kash-prd
NSG_NAME=nsg-kash-prd
PIP_NAME=pip-kash-prd
NIC_NAME=nic-kash-prd

# ── VM (size mirrors the legacy app host "genvm" = Standard_D2alds_v6) ────────
VM_NAME=vm-kash-prd
VM_SIZE=Standard_D2alds_v6
VM_IMAGE=MicrosoftWindowsServer:WindowsServer:2022-datacenter-azure-edition:latest
VM_ADMIN_USERNAME=kashadmin
# Restrict management access to YOUR IP only (default-deny otherwise).
RDP_SOURCE=                     # <-- fill: your.public.ip.addr  (RDP once for bootstrap, then never again)
RDP_DEFAULT_ACTION=Deny

# ── Observability ────────────────────────────────────────────────────────────
LOG_ANALYTICS_NAME=log-kash-prd

# ── Key Vault (lives in the PERMANENT shared RG; the VM pulls via managed identity)
# KV names are GLOBALLY unique, 3-24 chars. Add a short random suffix if taken.
KEYVAULT_NAME=kv-kash-prd
ENABLE_PURGE_PROTECTION=true    # prod: true — protects secrets from accidental/malicious purge

# ── On-box database (SQL Server Express, loopback-bound) ─────────────────────
# Prod runs its OWN on-box SQL Express seeded from the schema-only DACPAC + run-once
# migrations (same model as dev). The synthetic/smoke dev dataset is NOT seeded in
# prod (vm-seed gates it on Env=dev); prod gets reference rows + the bootstrap admin.
SQL_INSTANCE=SQLEXPRESS
DB_NAME=qrypto-card
DB_APP_LOGIN=kash_app           # least-privilege per-app SQL login (password in Key Vault as DB_PASSWORD)

# ── Cloudflare perimeter ─────────────────────────────────────────────────────
# Prod uses a NAMED tunnel (stable hostnames), so CLOUDFLARE_QUICK_TUNNEL=false and
# the Cloudflare API token + zone are REQUIRED (in config/.env.cloudflare.prd).
#
# DOMAIN: the durable prod domain is kash.cards. s16.xyz is a TEMPORARY (1-3 day)
# stand-in while the kash.cards zone is set up in Cloudflare. Launch on s16.xyz, then
# CUTOVER by flipping CLOUDFLARE_ZONE to kash.cards here AND PUBLIC_BASE_URL to
# https://app.kash.cards in secrets/.env.prd, re-seed the prd KV, re-run
# cloudflare-setup.sh, and redeploy. (Prerequisite: the kash.cards zone exists in
# Cloudflare and the prod API token covers it.)
CLOUDFLARE_ZONE=s16.xyz         # <-- flips to kash.cards at the domain cutover
CLOUDFLARE_QUICK_TUNNEL=false   # prod: named tunnel (stable hostnames)
CLOUDFLARE_TUNNEL_NAME=kash-prd
# CLOUDFLARE_API_TOKEN comes from config/.env.cloudflare.prd (or the app .vault / KV),
# never committed here.

# ── Source (build-on-box) ────────────────────────────────────────────────────
# Repo the VM clones to build on-box. Keep REPO_URL TOKENLESS. For a PRIVATE repo,
# put REPO_TOKEN in deploy/secrets/.vault.prd (seeded to Key Vault as REPO-TOKEN);
# vm-fetch-source pulls it via the VM managed identity, so the token never rides
# argv / run-command parameters / logs.
REPO_URL=https://github.com/egunawan85/kash-cards.git
REPO_BRANCH=main

# ── App secrets source ───────────────────────────────────────────────────────
# Path (relative to deploy/) to the prd app .env/.vault seeded into Key Vault.
# seed-kv-secrets.sh selects secrets/.env.<env> + secrets/.vault.<env> from ENV
# directly; these entries document the source for this environment.
APP_ENV_FILE=secrets/.env.prd
APP_VAULT_FILE=secrets/.vault.prd
