# deploy/config/.env.provision.dev.example
# Infra parameters for the DISPOSABLE dev shakeout box. Copy to
# ".env.provision.dev" and fill the operator-specific blanks (subscription id,
# your admin source IP). Sourced by the provision/deploy/perimeter scripts.
# Convention adapted from runegate-infra/config/.env.provision.<env>.
#
# The filled ".env.provision.dev" is GITIGNORED (contains subscription id + IPs);
# only this .example is committed.

# ── Environment ──────────────────────────────────────────────────────────────
ENV=dev

# ── Azure subscription / region ──────────────────────────────────────────────
# The throwaway dev box lives in the "Subscription qrypto" subscription
# (the live DB is under "Qrypto"; dev provisions separately).
AZURE_SUBSCRIPTION_NAME="Subscription qrypto"
AZURE_SUBSCRIPTION_ID=          # <-- fill: az account show --subscription "Subscription qrypto" --query id -o tsv
AZURE_LOCATION=southeastasia    # Singapore

# ── Resource groups ──────────────────────────────────────────────────────────
# Dev is torn down wholesale, so a SINGLE disposable RG holds everything
# (prod splits into rg-kash-shared [permanent KV+LA] + rg-kash-prd [compute]).
COMPUTE_RG=rg-kash-dev
SHARED_RG=rg-kash-dev

# ── Network (NSG denies inbound 443; the Cloudflare tunnel is outbound-only) ──
VNET_NAME=vnet-kash-dev
SUBNET_NAME=snet-kash-dev
NSG_NAME=nsg-kash-dev
PIP_NAME=pip-kash-dev
NIC_NAME=nic-kash-dev

# ── VM (size mirrors the legacy app host "genvm" = Standard_D2alds_v6) ────────
VM_NAME=vm-kash-dev
VM_SIZE=Standard_D2alds_v6
VM_IMAGE=MicrosoftWindowsServer:WindowsServer:2022-datacenter-azure-edition:latest
VM_ADMIN_USERNAME=kashadmin
# Restrict management access to YOUR IP only (default-deny otherwise).
RDP_SOURCE=                     # <-- fill: your.public.ip.addr  (RDP once for bootstrap, then never again)
RDP_DEFAULT_ACTION=Deny

# ── Observability ────────────────────────────────────────────────────────────
LOG_ANALYTICS_NAME=log-kash-dev

# ── Key Vault (full-rehearsal: dev seeds KV and the VM pulls via managed identity)
# KV names are GLOBALLY unique, 3-24 chars. Add a short random suffix if taken.
KEYVAULT_NAME=kv-kash-dev
ENABLE_PURGE_PROTECTION=false   # dev: false for easy teardown; prod: true

# ── On-box database (SQL Server Express, loopback-bound) ─────────────────────
# The dev box runs its OWN SQL Express seeded from the schema-only DACPAC; the
# live Azure SQL is never touched by the dev box.
SQL_INSTANCE=SQLEXPRESS
DB_NAME=qrypto-card
DB_APP_LOGIN=kash_app           # least-privilege per-app SQL login (password in Key Vault as DB_PASSWORD)

# ── Cloudflare perimeter ─────────────────────────────────────────────────────
# Zone for dev hostnames. If the kash.cards zone is not yet set up in Cloudflare,
# set CLOUDFLARE_QUICK_TUNNEL=true to use a throwaway trycloudflare.com URL for
# the dev shakeout (no account/zone needed) and defer the real zone to prod.
CLOUDFLARE_ZONE=kash.cards
CLOUDFLARE_QUICK_TUNNEL=true    # dev default until the kash.cards zone exists
CLOUDFLARE_TUNNEL_NAME=kash-dev
# CLOUDFLARE_API_TOKEN comes from the app .vault / KV, never committed here.

# ── Source (build-on-box) ────────────────────────────────────────────────────
# Repo the VM clones to build on-box. For a private repo, vm-fetch-source takes an
# optional short-lived token (passed out-of-band, never stored here).
REPO_URL=https://github.com/egunawan85/kash-cards.git
REPO_BRANCH=main

# ── App secrets source ───────────────────────────────────────────────────────
# Path (relative to deploy/) to the app .env/.vault seeded into Key Vault.
APP_ENV_FILE=secrets/.env
APP_VAULT_FILE=secrets/.vault
