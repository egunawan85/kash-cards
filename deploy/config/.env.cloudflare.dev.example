# deploy/config/.env.cloudflare.dev.example
# Cloudflare named-tunnel credentials. Copy to ".env.cloudflare.<env>" (e.g.
# ".env.cloudflare.dev") and fill. The filled file is GITIGNORED; only this
# .example is committed.
#
# Needed ONLY in named-tunnel mode (CLOUDFLARE_QUICK_TUNNEL=false in
# .env.provision.<env>); the quick-tunnel mode needs no Cloudflare account.
# These may also be supplied as environment variables instead of this file.
#
# Create the token at Cloudflare -> My Profile -> API Tokens -> Create Custom
# Token, scoped to the target zone:
#   - Zone : DNS : Edit
#   - Account : Cloudflare Tunnel : Edit
#
# Only CLOUDFLARE_API_TOKEN is strictly required — ACCOUNT_ID and ZONE_ID can be
# derived from the token via the Cloudflare API (GET /accounts, GET /zones).

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ---------------------------------------------------------------------------
# ROUTES: the public URLs for this environment (runegate-infra pattern).
# Each entry: "<prefix>:<service-url>"
#   hostname    = "<prefix>.<CLOUDFLARE_ZONE>"  (e.g. app-dev.s16.xyz)
#   service-url = the on-box loopback the tunnel forwards to (use 127.0.0.1, NOT
#                 localhost -- IIS binds IPv4 only). Port per deploy/config/sites.json.
# Sites NOT listed here get NO public hostname (deploy-iis still builds them loopback-
# only). Rename a prefix to rename the URL, then re-run cloudflare-setup.sh (idempotent).
# Backends (QryptoCard.API 8081, API.Admin 8083) are intentionally omitted -- the
# dashboards call them server-side over loopback. Scheduler (8085) + INT tiers + Scrapper
# stay internal too.
# ---------------------------------------------------------------------------
ROUTES=(
  "app-dev:http://127.0.0.1:8087"        # QryptoCard.Dashboard        (customer/merchant UI)
  "admin-dev:http://127.0.0.1:8088"      # QryptoCard.Dashboard.Admin  (admin UI, login-gated)
  "api-dev:http://127.0.0.1:8082"        # QryptoCard.API.Public       (programmatic, API-key)
  "callback-dev:http://127.0.0.1:8084"   # QryptoCard.API.Callback     (provider webhooks)
  "docs-dev:http://127.0.0.1:8086"       # QryptoCard.APIDocs
)
