<?xml version="1.0" encoding="utf-8"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  https://go.microsoft.com/fwlink/?LinkId=301879
  -->
<configuration>
  <appSettings>
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.6.2" />
    <httpRuntime targetFramework="4.6.2" />
  </system.web>
  <system.webServer>
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="*" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
  </system.webServer>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Web.Infrastructure" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-2.0.0.0" newVersion="2.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Helpers" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-3.0.0.0" newVersion="3.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Mvc" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-5.2.9.0" newVersion="5.2.9.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.WebPages" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="0.0.0.0-3.0.0.0" newVersion="3.0.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
  <system.codedom>
    <compilers>
      <compiler language="c#;cs;csharp" extension=".cs" type="Microsoft.CodeDom.Providers.DotNetCompilerPlatform.CSharpCodeProvider, Microsoft.CodeDom.Providers.DotNetCompilerPlatform, Version=2.0.1.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" warningLevel="4" compilerOptions="/langversion:default /nowarn:1659;1699;1701" />
      <compiler language="vb;vbs;visualbasic;vbscript" extension=".vb" type="Microsoft.CodeDom.Providers.DotNetCompilerPlatform.VBCodeProvider, Microsoft.CodeDom.Providers.DotNetCompilerPlatform, Version=2.0.1.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" warningLevel="4" compilerOptions="/langversion:default /nowarn:41008 /define:_MYTYPE=\&quot;Web\&quot; /optionInfer+" />
    </compilers>
  </system.codedom>
  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="BasicHttpBinding_IUserV1Service" />
        <binding name="BasicHttpBinding_ICardV1Service" />
        <binding name="BasicHttpBinding_IAdminV1Service" />
        <binding name="BasicHttpBinding_ISecurityService" />
        <binding name="BasicHttpBinding_IDashboardV1Service" />
        <binding name="BasicHttpBinding_IAuthV1Service" />
      </basicHttpBinding>
    </bindings>
    <client>
      <endpoint address="http://localhost:50434/Script/Service/Admin/v1/UserV1Service.svc"
        binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IUserV1Service"
        contract="UserV1Service.IUserV1Service" name="BasicHttpBinding_IUserV1Service" />
      <endpoint address="http://localhost:50434/Script/Service/Admin/v1/CardV1Service.svc"
        binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_ICardV1Service"
        contract="CardV1Service.ICardV1Service" name="BasicHttpBinding_ICardV1Service" />
      <endpoint address="http://localhost:50434/Script/Service/Admin/v1/AdminV1Service.svc"
        binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IAdminV1Service"
        contract="AdminV1Service.IAdminV1Service" name="BasicHttpBinding_IAdminV1Service" />
      <endpoint address="http://localhost:50434/Script/Service/SecurityService.svc"
        binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_ISecurityService"
        contract="AuthService.ISecurityService" name="BasicHttpBinding_ISecurityService" />
      <endpoint address="http://localhost:50434/Script/Service/Admin/v1/DashboardV1Service.svc"
        binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IDashboardV1Service"
        contract="DashboardV1Service.IDashboardV1Service" name="BasicHttpBinding_IDashboardV1Service" />
      <!-- AuthV1Service endpoint. Consumed via ChannelFactory<IAuthV1Service> in
           AuthTokenSecurity (NOT a generated proxy). The contract type resolves
           directly from the QryptoCard.INT project reference. -->
      <endpoint address="http://localhost:50434/Script/Service/Auth/v1/AuthV1Service.svc"
        binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IAuthV1Service"
        contract="QryptoCard.INT.Script.Service.Auth.v1.IAuthV1Service" name="BasicHttpBinding_IAuthV1Service" />
    </client>
  </system.serviceModel>
</configuration>